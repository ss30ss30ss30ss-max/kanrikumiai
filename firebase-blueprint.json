{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["manager", "accountant", "asst_accountant", "asst_manager", "resident"] },
        "roomNumber": { "type": "string" },
        "name": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isApproved"]
    },
    "Member": {
      "title": "Member Record",
      "description": "Resident directory information",
      "type": "object",
      "properties": {
        "roomNumber": { "type": "string" },
        "parkingNumber": { "type": "string" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomNumber", "name"]
    },
    "Accounting": {
      "title": "Accounting Record",
      "description": "Income and expense tracking",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "authorUid": { "type": "string" }
      },
      "required": ["date", "type", "amount"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Notices for residents",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" },
        "fileUrl": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "Shared events and schedules",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "startDate", "endDate"]
    },
    "Log": {
      "title": "System Log",
      "description": "Audit trail for actions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["uid", "action", "timestamp"]
    },
    "DistributionDocument": {
      "title": "Distribution Document",
      "description": "Formal documents for printing and distribution",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "sender": { "type": "string" },
        "recipient": { "type": "string" },
        "content": { "type": "string" },
        "footer": { "type": "string" },
        "template": { "type": "string", "enum": ["notice", "meeting", "request"] },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "sender", "recipient", "content", "template", "authorUid"]
    },
    "BulletinPost": {
      "title": "Bulletin Board Post",
      "description": "Community discussion posts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRoom": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "content": { "type": "string" },
              "authorUid": { "type": "string" },
              "authorName": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["title", "content", "authorUid", "authorName", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Direct messages between residents and managers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "roomNumber": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "unreadByManager": { "type": "boolean" },
        "unreadByResident": { "type": "boolean" }
      },
      "required": ["userId", "userName", "roomNumber", "subject", "status", "createdAt"]
    },
    "InquiryMessage": {
      "title": "Inquiry Message",
      "description": "Individual messages within an inquiry thread",
      "type": "object",
      "properties": {
        "inquiryId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["inquiryId", "senderId", "senderName", "content", "createdAt"]
    },
    "ParkingReservation": {
      "title": "Parking Reservation",
      "description": "Visitor parking spot reservation",
      "type": "object",
      "properties": {
        "spaceNumber": { "type": "integer" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "roomNumber": { "type": "string" },
        "carNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["spaceNumber", "date", "startTime", "endTime", "userId", "userName", "roomNumber", "carNumber", "createdAt"]
    },
    "ParkingSettings": {
      "title": "Parking Settings",
      "description": "Global settings for parking reservation",
      "type": "object",
      "properties": {
        "isPublic": { "type": "boolean" }
      },
      "required": ["isPublic"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/members/{roomNumber}": { "schema": "Member", "description": "Resident directory" },
    "/accounting/{id}": { "schema": "Accounting", "description": "Financial records" },
    "/announcements/{id}": { "schema": "Announcement", "description": "Notices" },
    "/calendar_events/{id}": { "schema": "CalendarEvent", "description": "Schedule" },
    "/logs/{id}": { "schema": "Log", "description": "Audit logs" },
    "/documents/{id}": { "schema": "DistributionDocument", "description": "Formal documents" },
    "/bulletin_posts/{id}": { "schema": "BulletinPost", "description": "Community posts" },
    "/inquiries/{id}": { "schema": "Inquiry", "description": "Support inquiries" },
    "/inquiries/{id}/messages/{messageId}": { "schema": "InquiryMessage", "description": "Messages in an inquiry" },
    "/parking_reservations/{id}": { "schema": "ParkingReservation", "description": "Parking spot bookings" },
    "/settings/parking": { "schema": "ParkingSettings", "description": "Parking feature configuration" }
  }
}
